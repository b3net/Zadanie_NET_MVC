@model IEnumerable<Project.Models.MessageModel>
@using Project.Resources
  
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewBag.Title</h2>
    @Html.ActionLink(AppResources.NewMessage, "Create", null, new { @class = "btn btn-primary" })
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th class="col-name @(ViewBag.CurrentSort == "first_name" || ViewBag.CurrentSort == "first_name_desc" ? "active-sort" : "")">
                    <a href="@Url.Action("List", new { sortOrder = ViewBag.FirstNameSortParm })" class="sort-link">
                        @AppResources.FirstName @Html.SortIcon("first_name", (string)ViewBag.CurrentSort)
                    </a>
                </th>
                <th class="col-name @(ViewBag.CurrentSort == "last_name" || ViewBag.CurrentSort == "last_name_desc" ? "active-sort" : "")">
                    <a href="@Url.Action("List", new { sortOrder = ViewBag.LastNameSortParm })" class="sort-link">
                        @AppResources.LastName @Html.SortIcon("last_name", (string)ViewBag.CurrentSort)
                    </a>
                </th>
                <th class="col-email @(ViewBag.CurrentSort == "email" || ViewBag.CurrentSort == "email_desc" ? "active-sort" : "")">
                    <a href="@Url.Action("List", new { sortOrder = ViewBag.EmailSortParm })" class="sort-link">
                        @AppResources.Email @Html.SortIcon("email", (string)ViewBag.CurrentSort)
                    </a>
                </th>
                <th class="col-message">
                    @AppResources.Message
                </th>
                <th class="col-date @(string.IsNullOrEmpty(ViewBag.CurrentSort) || ViewBag.CurrentSort == "date" || ViewBag.CurrentSort == "date_desc" ? "active-sort" : "")">
                    <a href="@Url.Action("List", new { sortOrder = ViewBag.DateSortParm })" class="sort-link">
                        @AppResources.Date @Html.SortIcon("date", (string)ViewBag.CurrentSort)
                    </a>
                </th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="text-truncate">@item.FirstName</td>
                        <td class="text-truncate">@item.LastName</td>
                        <td class="text-truncate">@item.Email</td>
                        <td class="text-break">
                            <span class="message-preview-trigger" 
                                  onclick="previewMessage(this)" 
                                  data-full-content="@item.Content"
                                  title="@AppResources.Preview"
                                  style="cursor: pointer; display: block;">
                                @Html.TruncateHtml(item.Content, 100)
                            </span>
                        </td>
                        <td>@item.CreatedAt.ToString("g")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@Html.Partial("~/Views/Shared/Components/_MessagePreviewModal.cshtml")

<div class="d-flex justify-content-end">
    @Html.Partial("~/Views/Shared/Components/_Pagination.cshtml")
</div>

@section Scripts {
    <script>
        function previewMessage(btn) {
            var content = $(btn).data('full-content');
            $('#previewContent').html(content);
            var myModal = new bootstrap.Modal(document.getElementById('previewModal'));
            myModal.show();
        }
    </script>
}
