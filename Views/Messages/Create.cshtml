@model Project.Models.MessageModel
@using Project.Resources

<div class="row">
    <div class="col-md-9 mx-auto">
        <h2 class="mb-4">@ViewBag.Title</h2>

        @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "contactForm" }))
        {
            @Html.AntiForgeryToken()

            <div class="form-horizontal">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(model => model.FirstName, htmlAttributes: new { @class = "form-label fw-bold" })
                        @Html.EditorFor(model => model.FirstName, new { htmlAttributes = new { @class = "form-control", placeholder = AppResources.FirstNamePlaceholder } })
                        @Html.ValidationMessageFor(model => model.FirstName, "", new { @class = "text-danger small" })
                    </div>

                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(model => model.LastName, htmlAttributes: new { @class = "form-label fw-bold" })
                        @Html.EditorFor(model => model.LastName, new { htmlAttributes = new { @class = "form-control", placeholder = AppResources.LastNamePlaceholder } })
                        @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-danger small" })
                    </div>
                </div>

                <div class="mb-3">
                    @Html.LabelFor(model => model.Email, htmlAttributes: new { @class = "form-label fw-bold" })
                    @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control", placeholder = AppResources.EmailPlaceholder } })
                    @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-4">
                    @Html.LabelFor(model => model.Content, htmlAttributes: new { @class = "form-label fw-bold" })
                    @Html.Partial("~/Views/Shared/Components/_TextEditor.cshtml", Model.Content ?? "")
                    @Html.ValidationMessageFor(model => model.Content, "", new { @class = "text-danger small" })
                </div>

                <div class="d-flex justify-content-between">
                    <a href="@Url.Action("List")" class="btn btn-secondary">@AppResources.BackToList</a>
                    <button type="submit" class="btn btn-primary"> @AppResources.Save </button>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $.validator.addMethod("strictemail", function (value, element, params) {
            if (this.optional(element)) return true;
            var pattern = params.pattern;
            var regex = new RegExp(pattern);
            return regex.test(value);
        });

        $.validator.unobtrusive.adapters.add("strictemail", ["pattern"], function (options) {
            options.rules["strictemail"] = {
                pattern: options.params.pattern
            };
            options.messages["strictemail"] = options.message;
        });

        if (!$.validator.methods.notblank) {
            $.validator.addMethod("notblank", function (value, element) {
                return value && value.replace(/<[^>]*>/g, '').trim().length > 0;
            });
            
            $.validator.unobtrusive.adapters.addBool("notblank");
        }
    </script>
}
